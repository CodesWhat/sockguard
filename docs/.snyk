# Snyk (https://snyk.io) policy file — mirror of the root .snyk ignore.
# Snyk resolves this workspace's package.json standalone (no root
# lockfile or npm overrides context), so it reports next's pinned
# postcss 8.4.31 even though overrides force ^8.5.15 and the installed
# tree contains no vulnerable version.
version: v1.25.0
ignore:
  SNYK-JS-POSTCSS-16189065:
    - '*':
        reason: >-
          Not installed: npm overrides pin postcss to ^8.5.15; the
          lockfile has no 8.4.31. Snyk manifest-only resolution does
          not apply npm overrides.
        expires: 2026-09-15T00:00:00.000Z
        created: 2026-06-11T00:00:00.000Z
patch: {}
