{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs"],
      "ignoreBinaries": ["helm"]
    },
    "docs": {
      "entry": ["source.config.ts"]
    },
    "website": {
      "entry": ["scripts/*.mjs"],
      "ignore": ["src/components/ui/**"],
      "ignoreBinaries": ["magick"]
    }
  }
}
