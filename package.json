{
  "private": true,
  "workspaces": [
    "website",
    "docs"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "npm --workspaces --if-present test && node --test --experimental-strip-types scripts/*.test.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "prepare": "test -d .git && lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "knip": "6.4.1",
    "lefthook": "^2.1.5",
    "turbo": "^2.9.6"
  },
  "overrides": {
    "next@16.2.3": {
      ".": "16.2.3",
      "postcss": "8.5.10"
    },
    "postcss": "^8.5.10"
  },
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
