{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "out/**", "dist/**"]
    },
    "website#build": {
      "dependsOn": ["docs#build"],
      "outputs": [".next/**", "!.next/cache/**", "out/**", "public/docs/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    }
  }
}
